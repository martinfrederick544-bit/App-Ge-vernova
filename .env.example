# ============================================================
# GE Vernova — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# ---- Supabase ----
# Trouvez ces valeurs dans : Supabase Dashboard > Project Settings > API

# URL du projet Supabase (publique, safe côté client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anonyme Supabase (publique, safe côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role Supabase (SECRÈTE — jamais exposée côté client)
# Utilisée uniquement dans les API routes (server-side) pour:
# - Insérer dans audit_log
# - Insérer des notifications
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Resend (emails transactionnels) ----
# Créez un compte sur https://resend.com et générez une API key
# Vérifiez votre domaine d'envoi dans Resend > Domains
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Application ----
# URL publique de l'application (sans slash final)
# En développement : http://localhost:3000
# En production : https://votre-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
